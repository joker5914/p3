    {
      "name": "Districts (super_admin)",
      "item": [
        { "name": "List Districts", "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/api/v1/admin/districts", "host": ["{{baseUrl}}"], "path": ["api","v1","admin","districts"] } } },
        { "name": "Get District", "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/api/v1/admin/districts/{{districtId}}", "host": ["{{baseUrl}}"], "path": ["api","v1","admin","districts","{{districtId}}"] } } },
        { "name": "District Stats (locations / users / scans / devices)", "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/api/v1/admin/districts/{{districtId}}/stats", "host": ["{{baseUrl}}"], "path": ["api","v1","admin","districts","{{districtId}}","stats"] } } },
        {
          "name": "Create District",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Fairview School District\",\n  \"admin_email\": \"superintendent@fvsd.edu\",\n  \"timezone\": \"America/Chicago\",\n  \"is_licensed\": true,\n  \"license_tier\": \"standard\",\n  \"license_expires_at\": \"2027-06-30\",\n  \"notes\": \"\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/v1/admin/districts", "host": ["{{baseUrl}}"], "path": ["api","v1","admin","districts"] }
          }
        },
        {
          "name": "Update District",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Fairview School District\",\n  \"status\": \"active\",\n  \"is_licensed\": true,\n  \"license_tier\": \"premium\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/v1/admin/districts/{{districtId}}", "host": ["{{baseUrl}}"], "path": ["api","v1","admin","districts","{{districtId}}"] }
          }
        },
        { "name": "Delete District (must be empty)", "request": { "method": "DELETE", "url": { "raw": "{{baseUrl}}/api/v1/admin/districts/{{districtId}}", "host": ["{{baseUrl}}"], "path": ["api","v1","admin","districts","{{districtId}}"] } } }
      ]
    },

    {
      "name": "Schools / Locations",
      "item": [
        {
          "name": "List Schools (optional ?district_id filter)",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/v1/admin/schools?district_id={{districtId}}", "host": ["{{baseUrl}}"], "path": ["api","v1","admin","schools"], "query": [{ "key": "district_id", "value": "{{districtId}}" }] },
            "description": "super_admin sees every school when no filter set; district_admin is forced to their own district regardless."
          }
        },
        { "name": "School Stats (plates / users / scans / devices)", "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/api/v1/admin/schools/{{schoolId}}/stats", "host": ["{{baseUrl}}"], "path": ["api","v1","admin","schools","{{schoolId}}","stats"] } } },
        {
          "name": "Create School (inside a district)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Campus 1\",\n  \"district_id\": \"{{districtId}}\",\n  \"admin_email\": \"principal@campus1.edu\",\n  \"timezone\": \"America/Chicago\",\n  \"is_licensed\": true,\n  \"license_tier\": \"standard\",\n  \"license_expires_at\": \"2027-06-30\",\n  \"address\": \"123 Main St\",\n  \"phone\": \"(555) 555-0100\",\n  \"website\": \"https://campus1.edu\",\n  \"notes\": \"\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/v1/admin/schools", "host": ["{{baseUrl}}"], "path": ["api","v1","admin","schools"] }
          }
        },
        {
          "name": "Update School",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Campus 1\",\n  \"status\": \"active\",\n  \"is_licensed\": true\n}" },
            "url": { "raw": "{{baseUrl}}/api/v1/admin/schools/{{schoolId}}", "host": ["{{baseUrl}}"], "path": ["api","v1","admin","schools","{{schoolId}}"] }
          }
        },
        {
          "name": "Lookup School by Enrollment Code",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/v1/schools/lookup?code=ABC123", "host": ["{{baseUrl}}"], "path": ["api","v1","schools","lookup"], "query": [{ "key": "code", "value": "ABC123" }] }
          }
        }
      ]
    },

    {
      "name": "Students (admin)",
      "item": [
        { "name": "List Students", "request": { "method": "GET", "header": [{ "key": "X-School-Id", "value": "{{schoolId}}" }], "url": { "raw": "{{baseUrl}}/api/v1/admin/students", "host": ["{{baseUrl}}"], "path": ["api","v1","admin","students"] } } },
        { "name": "Unlink Student", "request": { "method": "POST", "header": [{ "key": "X-School-Id", "value": "{{schoolId}}" }], "url": { "raw": "{{baseUrl}}/api/v1/admin/students/{{studentId}}/unlink", "host": ["{{baseUrl}}"], "path": ["api","v1","admin","students","{{studentId}}","unlink"] } } },
        {
          "name": "Link Student to Guardian",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "X-School-Id", "value": "{{schoolId}}" }],
            "body": { "mode": "raw", "raw": "{\n  \"guardian_email\": \"jane@example.com\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/v1/admin/students/{{studentId}}/link", "host": ["{{baseUrl}}"], "path": ["api","v1","admin","students","{{studentId}}","link"] }
          }
        }
      ]
    },

    {
      "name": "Guardians (admin)",
      "item": [
        { "name": "List Guardians", "request": { "method": "GET", "header": [{ "key": "X-School-Id", "value": "{{schoolId}}" }], "url": { "raw": "{{baseUrl}}/api/v1/admin/guardians?search=", "host": ["{{baseUrl}}"], "path": ["api","v1","admin","guardians"], "query": [{ "key": "search", "value": "" }] } } },
        { "name": "Guardian Detail", "request": { "method": "GET", "header": [{ "key": "X-School-Id", "value": "{{schoolId}}" }], "url": { "raw": "{{baseUrl}}/api/v1/admin/guardians/{{guardianUid}}/detail", "host": ["{{baseUrl}}"], "path": ["api","v1","admin","guardians","{{guardianUid}}","detail"] } } },
        {
          "name": "Update Guardian Profile",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "X-School-Id", "value": "{{schoolId}}" }],
            "body": { "mode": "raw", "raw": "{\n  \"display_name\": \"Jane Guardian\",\n  \"phone\": \"+15555550199\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/v1/admin/guardians/{{guardianUid}}/profile", "host": ["{{baseUrl}}"], "path": ["api","v1","admin","guardians","{{guardianUid}}","profile"] }
          }
        },
        {
          "name": "Assign School to Guardian",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "X-School-Id", "value": "{{schoolId}}" }],
            "body": { "mode": "raw", "raw": "{\n  \"school_id\": \"{{schoolId}}\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/v1/admin/guardians/{{guardianUid}}/schools", "host": ["{{baseUrl}}"], "path": ["api","v1","admin","guardians","{{guardianUid}}","schools"] }
          }
        },
        { "name": "Remove School from Guardian", "request": { "method": "DELETE", "header": [{ "key": "X-School-Id", "value": "{{schoolId}}" }], "url": { "raw": "{{baseUrl}}/api/v1/admin/guardians/{{guardianUid}}/schools/{{schoolId}}", "host": ["{{baseUrl}}"], "path": ["api","v1","admin","guardians","{{guardianUid}}","schools","{{schoolId}}"] } } }
      ]
    },

    {
      "name": "Devices",
      "item": [
        {
          "name": "List Devices",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/v1/devices", "host": ["{{baseUrl}}"], "path": ["api","v1","devices"] },
            "description": "super_admin sees every device; district_admin is scoped to devices assigned to their district."
          }
        },
        { "name": "Get Device", "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/api/v1/devices/{{hostname}}", "host": ["{{baseUrl}}"], "path": ["api","v1","devices","{{hostname}}"] } } },
        {
          "name": "Update Device (location / district / school)",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"location\": \"entry\",\n  \"district_id\": \"{{districtId}}\",\n  \"school_id\": \"{{schoolId}}\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/v1/devices/{{hostname}}", "host": ["{{baseUrl}}"], "path": ["api","v1","devices","{{hostname}}"] },
            "description": "super_admin can set district_id + school_id; district_admin can only set school_id on devices already in their district. Empty string = unassign. Changing district clears school_id."
          }
        }
      ]
