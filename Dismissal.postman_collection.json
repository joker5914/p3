        { "name": "Delete User", "request": { "method": "DELETE", "header": [{ "key": "X-School-Id", "value": "{{schoolId}}" }], "url": { "raw": "{{baseUrl}}/api/v1/users/{{targetUid}}", "host": ["{{baseUrl}}"], "path": ["api","v1","users","{{targetUid}}"] } } },
        { "name": "Resend Invite", "request": { "method": "POST", "header": [{ "key": "X-School-Id", "value": "{{schoolId}}" }], "url": { "raw": "{{baseUrl}}/api/v1/users/{{targetUid}}/resend-invite", "host": ["{{baseUrl}}"], "path": ["api","v1","users","{{targetUid}}","resend-invite"] } } }
      ]
    },

