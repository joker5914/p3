    {
      "name": "Platform Users (super_admin)",
      "item": [
        {
          "name": "List Platform Users",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/v1/admin/platform-users", "host": ["{{baseUrl}}"], "path": ["api","v1","admin","platform-users"] },
            "description": "Every school_admins record with resolved district_name + school_name + Firebase Auth metadata."
          }
        },
        {
          "name": "Reassign Platform User",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"role\": \"school_admin\",\n  \"district_id\": \"{{districtId}}\",\n  \"school_id\": \"{{schoolId}}\",\n  \"status\": \"active\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/v1/admin/platform-users/{{targetUid}}", "host": ["{{baseUrl}}"], "path": ["api","v1","admin","platform-users","{{targetUid}}"] },
            "description": "All fields optional. Empty-string on scope fields unassigns. Role `super_admin` auto-clears scope. Mirrors to Firebase Auth custom claims."
          }
        }
      ]
    },

    {
      "name": "Data Integrity (super_admin)",
      "item": [
        {
          "name": "Run Integrity Check",
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/api/v1/admin/integrity/check", "host": ["{{baseUrl}}"], "path": ["api","v1","admin","integrity","check"] },
            "description": "Sweeps districts, schools, devices, school_admins, Firebase Auth claims. Returns a report with `ok`, `summary.fixed`, `summary.warnings`, and per-check details. Idempotent — re-running is safe."
          }
        },
        {
          "name": "Fix Orphans — Scans (destructive)",
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/api/v1/admin/integrity/fix-orphans?category=scans", "host": ["{{baseUrl}}"], "path": ["api","v1","admin","integrity","fix-orphans"], "query": [{ "key": "category", "value": "scans" }] },
            "description": "Permanently deletes plate_scans rows whose school_id no longer exists. Irreversible."
          }
        },
        {
          "name": "Fix Orphans — Admins",
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/api/v1/admin/integrity/fix-orphans?category=admins", "host": ["{{baseUrl}}"], "path": ["api","v1","admin","integrity","fix-orphans"], "query": [{ "key": "category", "value": "admins" }] },
            "description": "Clears stale school_id / district_id on admin docs whose referents are gone. Accounts stay active but become unscoped."
          }
        },
        {
          "name": "Fix Orphans — Devices",
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/api/v1/admin/integrity/fix-orphans?category=devices", "host": ["{{baseUrl}}"], "path": ["api","v1","admin","integrity","fix-orphans"], "query": [{ "key": "category", "value": "devices" }] },
            "description": "Clears stale school_id on devices whose referenced school is gone. Device returns to 'awaiting school assignment'."
          }
        }
      ]
    },

