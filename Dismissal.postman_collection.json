{
  "info": {
    "name": "Dismissal API",
    "description": "Complete API collection for the Dismissal backend. Auth uses Firebase ID tokens passed as `Authorization: Bearer <firebase_id_token>`. In development mode the backend bypasses auth when no token is present.\n\nSet `baseUrl` to your backend (Cloud Run URL in prod, http://localhost:8000 in dev). On first request the collection auto-generates a Firebase ID token using `testEmail` + `testPassword`; you can also sign in manually via the **Authentication → Generate Token** request.\n\nContext headers (only send when relevant):\n- `X-School-Id`: scopes an admin request to a specific school. Required for super_admin / district_admin when calling school-scoped endpoints.\n- `X-District-Id`: scopes a super_admin request to a specific district. Required for district-level list endpoints.",
    "version": "2.0.0",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "https://dismissal-backend-375142531842.us-central1.run.app", "type": "string" },
    { "key": "token", "value": "<firebase_id_token>", "type": "string" },
    { "key": "firebaseApiKey", "value": "AIzaSyAptP2cM_xj764rrwC4FRnbmnQJwFsLvFM", "type": "string", "description": "Firebase Web API key (from Firebase project settings)" },
    { "key": "testEmail", "value": "cgillett5914@gmail.com", "type": "string", "description": "Email for the test user used to generate tokens" },
    { "key": "testPassword", "value": "<your_password>", "type": "string", "description": "Password for the test user used to generate tokens" },
    { "key": "schoolId", "value": "<school_id>", "type": "string", "description": "Used in X-School-Id header for super_admin / district_admin school-scoped calls" },
    { "key": "districtId", "value": "<district_id>", "type": "string", "description": "Used in X-District-Id header for super_admin district-scoped calls" },
    { "key": "plate", "value": "ABC123", "type": "string" },
    { "key": "plateToken", "value": "<plate_token>", "type": "string" },
    { "key": "firestoreId", "value": "<firestore_id>", "type": "string" },
    { "key": "targetUid", "value": "<target_uid>", "type": "string" },
    { "key": "hostname", "value": "Dismissal-Edge-6064cae5", "type": "string" },
    { "key": "studentId", "value": "<student_id>", "type": "string" },
    { "key": "guardianUid", "value": "<guardian_uid>", "type": "string" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Auto-generate Firebase ID token if not already set or looks like a placeholder.",
          "const token = pm.collectionVariables.get(\"token\");",
          "if (!token || token === \"<firebase_id_token>\") {",
          "    const apiKey = pm.collectionVariables.get(\"firebaseApiKey\");",
          "    const email = pm.collectionVariables.get(\"testEmail\");",
          "    const password = pm.collectionVariables.get(\"testPassword\");",
          "    if (!password || password === \"<your_password>\") {",
          "        console.warn(\"Set testPassword in collection variables to auto-generate tokens.\");",
          "        return;",
          "    }",
          "    pm.sendRequest({",
          "        url: \"https://identitytoolkit.googleapis.com/v1/accounts:signInWithPassword?key=\" + apiKey,",
          "        method: \"POST\",",
          "        header: { \"Content-Type\": \"application/json\" },",
          "        body: { mode: \"raw\", raw: JSON.stringify({ email: email, password: password, returnSecureToken: true }) }",
          "    }, function (err, res) {",
          "        if (!err && res.code === 200) {",
          "            pm.collectionVariables.set(\"token\", res.json().idToken);",
          "            console.log(\"Token auto-generated and saved.\");",
          "        } else {",
          "            console.error(\"Token auto-generation failed:\", err || res.text());",
          "        }",
          "    });",
          "}"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "System",
      "item": [
        {
          "name": "Health Check (public)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/v1/system/health", "host": ["{{baseUrl}}"], "path": ["api","v1","system","health"] },
            "description": "Public liveness probe. No auth required."
          }
        },
        {
          "name": "System Alerts (school-scoped)",
          "request": {
            "method": "GET",
            "header": [{ "key": "X-School-Id", "value": "{{schoolId}}" }],
            "url": { "raw": "{{baseUrl}}/api/v1/system/alerts", "host": ["{{baseUrl}}"], "path": ["api","v1","system","alerts"] },
            "description": "Active system alerts (low-confidence scans, backend errors)."
          }
        }
      ]
    },

    {
      "name": "Authentication",
      "item": [
        {
          "name": "Generate Token (email / password)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"{{testEmail}}\",\n  \"password\": \"{{testPassword}}\",\n  \"returnSecureToken\": true\n}" },
            "url": { "raw": "https://identitytoolkit.googleapis.com/v1/accounts:signInWithPassword?key={{firebaseApiKey}}", "protocol": "https", "host": ["identitytoolkit","googleapis","com"], "path": ["v1","accounts:signInWithPassword"], "query": [{ "key": "key", "value": "{{firebaseApiKey}}" }] },
            "description": "Exchanges email/password for a Firebase ID token. Copy `idToken` into the `token` collection variable, or rely on the pre-request hook."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    pm.collectionVariables.set(\"token\", pm.response.json().idToken);",
                  "    console.log(\"Token saved to collection variables.\");",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/api/v1/auth/logout", "host": ["{{baseUrl}}"], "path": ["api","v1","auth","logout"] }
          }
        },
        {
          "name": "Guardian Signup",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"display_name\": \"Jane Guardian\",\n  \"email\": \"jane@example.com\",\n  \"phone\": \"+15555550199\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/v1/auth/guardian-signup", "host": ["{{baseUrl}}"], "path": ["api","v1","auth","guardian-signup"] },
            "description": "Self-service sign-up for a guardian account. Token must come from a freshly-created Firebase user."
          }
        }
      ]
    },

    {
      "name": "Current User",
      "item": [
        {
          "name": "Get My Profile",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/v1/me", "host": ["{{baseUrl}}"], "path": ["api","v1","me"] },
            "description": "Returns the caller's profile + permissions. Respects X-School-Id / X-District-Id for super_admins picking a scope."
          }
        },
        {
          "name": "Update My Profile",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"display_name\": \"New Name\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/v1/me", "host": ["{{baseUrl}}"], "path": ["api","v1","me"] }
          }
        }
      ]
    },

    {
      "name": "Scanner",
      "item": [
        {
          "name": "Register Device (scanner)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"hostname\": \"{{hostname}}\",\n  \"cpu_serial\": \"0000000012345678\",\n  \"mac_address\": \"aa:bb:cc:dd:ee:ff\",\n  \"ip_address\": \"10.0.0.42\",\n  \"firmware_sha\": \"abc1234\",\n  \"started_at\": \"2026-04-19T01:55:00Z\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/v1/devices/register", "host": ["{{baseUrl}}"], "path": ["api","v1","devices","register"] },
            "description": "Called by the scanner on startup. Requires a scanner-minted Firebase token."
          }
        },
        {
          "name": "Heartbeat (scanner + health snapshot)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"hostname\": \"{{hostname}}\",\n  \"ip_address\": \"10.0.0.42\",\n  \"sent_at\": \"2026-04-19T02:00:00Z\",\n  \"health\": {\n    \"healthy\": true,\n    \"uptime_seconds\": 1932,\n    \"cpu_temp_c\": 56.8,\n    \"memory_total_mb\": 8192,\n    \"memory_used_mb\": 245,\n    \"memory_available_mb\": 7947,\n    \"service_scanner\": \"active\",\n    \"service_watchdog\": \"active\",\n    \"reported_at\": \"2026-04-19T02:00:00Z\"\n  }\n}" },
            "url": { "raw": "{{baseUrl}}/api/v1/devices/heartbeat", "host": ["{{baseUrl}}"], "path": ["api","v1","devices","heartbeat"] }
          }
        },
        {
          "name": "Submit Plate Scan (recognized)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-School-Id", "value": "{{schoolId}}", "description": "Required when posting as an admin role. Scanner tokens resolve school from the device record." }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"plate\": \"{{plate}}\",\n  \"timestamp\": \"2026-04-19T14:25:00Z\",\n  \"location\": \"entry\",\n  \"confidence_score\": 0.92,\n  \"thumbnail_b64\": null\n}" },
            "url": { "raw": "{{baseUrl}}/api/v1/scan", "host": ["{{baseUrl}}"], "path": ["api","v1","scan"] },
            "description": "Recognized plate from the scanner. Scanner tokens carry an assigned school (see Devices.patch); admin-posted scans must send X-School-Id or the backend 400s to prevent silent misroutes."
          }
        },
        {
          "name": "Submit Unrecognized Scan (with thumbnail)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-School-Id", "value": "{{schoolId}}", "description": "Required when posting as an admin role." }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"timestamp\": \"2026-04-19T14:25:00Z\",\n  \"location\": \"entry\",\n  \"ocr_guess\": \"DTL56X\",\n  \"confidence_score\": 0.41,\n  \"reason\": \"low_confidence\",\n  \"thumbnail_b64\": null\n}" },
            "url": { "raw": "{{baseUrl}}/api/v1/scan/unrecognized", "host": ["{{baseUrl}}"], "path": ["api","v1","scan","unrecognized"] },
            "description": "Scanner found a plate-shaped region but OCR didn't pass. Surfaces on the Dashboard so an admin can eyeball the thumbnail."
          }
        }
      ]
    },

    {
      "name": "Dashboard & Queue",
      "item": [
        {
          "name": "Get Live Queue",
          "request": {
            "method": "GET",
            "header": [{ "key": "X-School-Id", "value": "{{schoolId}}" }],
            "url": { "raw": "{{baseUrl}}/api/v1/dashboard", "host": ["{{baseUrl}}"], "path": ["api","v1","dashboard"] }
          }
        },
        {
          "name": "Dismiss Entry by Plate Token",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "X-School-Id", "value": "{{schoolId}}" }],
            "url": { "raw": "{{baseUrl}}/api/v1/queue/{{plateToken}}?pickup_method=manual", "host": ["{{baseUrl}}"], "path": ["api","v1","queue","{{plateToken}}"], "query": [{ "key": "pickup_method", "value": "manual" }] }
          }
        },
        {
          "name": "Remove Entry by Raw Plate",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "X-School-Id", "value": "{{schoolId}}" }],
            "url": { "raw": "{{baseUrl}}/api/v1/plate/{{plate}}", "host": ["{{baseUrl}}"], "path": ["api","v1","plate","{{plate}}"] }
          }
        },
        {
          "name": "Bulk Pickup (mark everyone arrived)",
          "request": {
            "method": "POST",
            "header": [{ "key": "X-School-Id", "value": "{{schoolId}}" }],
            "url": { "raw": "{{baseUrl}}/api/v1/queue/bulk-pickup", "host": ["{{baseUrl}}"], "path": ["api","v1","queue","bulk-pickup"] }
          }
        }
      ]
    },

    {
      "name": "History & Reports",
      "item": [
        {
          "name": "Get Scan History",
          "request": {
            "method": "GET",
            "header": [{ "key": "X-School-Id", "value": "{{schoolId}}" }],
            "url": { "raw": "{{baseUrl}}/api/v1/history?start_date=2026-04-01&end_date=2026-04-30&limit=200", "host": ["{{baseUrl}}"], "path": ["api","v1","history"], "query": [{ "key": "start_date", "value": "2026-04-01" }, { "key": "end_date", "value": "2026-04-30" }, { "key": "search", "value": "", "disabled": true }, { "key": "limit", "value": "200" }] }
          }
        },
        {
          "name": "Reports — Summary",
          "request": {
            "method": "GET",
            "header": [{ "key": "X-School-Id", "value": "{{schoolId}}" }],
            "url": { "raw": "{{baseUrl}}/api/v1/reports/summary?start_date=2026-04-01&end_date=2026-04-30", "host": ["{{baseUrl}}"], "path": ["api","v1","reports","summary"], "query": [{ "key": "start_date", "value": "2026-04-01" }, { "key": "end_date", "value": "2026-04-30" }] }
          }
        },
        {
          "name": "Insights — Summary",
          "request": {
            "method": "GET",
            "header": [{ "key": "X-School-Id", "value": "{{schoolId}}" }],
            "url": { "raw": "{{baseUrl}}/api/v1/insights/summary", "host": ["{{baseUrl}}"], "path": ["api","v1","insights","summary"] }
          }
        }
      ]
    },

    {
      "name": "Plate Registry",
      "item": [
        {
          "name": "List Plates",
          "request": {
            "method": "GET",
            "header": [{ "key": "X-School-Id", "value": "{{schoolId}}" }],
            "url": { "raw": "{{baseUrl}}/api/v1/plates", "host": ["{{baseUrl}}"], "path": ["api","v1","plates"] }
          }
        },
        {
          "name": "Update Plate",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "X-School-Id", "value": "{{schoolId}}" }],
            "body": { "mode": "raw", "raw": "{\n  \"plate_number\": \"ABC123\",\n  \"guardian_name\": \"Jane Guardian\",\n  \"student_names\": [\"Alice Smith\"],\n  \"vehicle_make\": \"Toyota\",\n  \"vehicle_model\": \"Sienna\",\n  \"vehicle_color\": \"Blue\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/v1/plates/{{plateToken}}", "host": ["{{baseUrl}}"], "path": ["api","v1","plates","{{plateToken}}"] }
          }
        },
        {
          "name": "Delete Plate",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "X-School-Id", "value": "{{schoolId}}" }],
            "url": { "raw": "{{baseUrl}}/api/v1/plates/{{plateToken}}", "host": ["{{baseUrl}}"], "path": ["api","v1","plates","{{plateToken}}"] }
          }
        },
        {
          "name": "Bulk Import Plates",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "X-School-Id", "value": "{{schoolId}}" }],
            "body": { "mode": "raw", "raw": "[\n  {\n    \"guardian_id\": \"G001\",\n    \"guardian_name\": \"Jane Guardian\",\n    \"student_id\": \"S001\",\n    \"student_name\": \"Alice Smith\",\n    \"plate_number\": \"ABC123\"\n  }\n]" },
            "url": { "raw": "{{baseUrl}}/api/v1/admin/import-plates", "host": ["{{baseUrl}}"], "path": ["api","v1","admin","import-plates"] }
          }
        },
        {
          "name": "List Duplicate Candidates",
          "request": {
            "method": "GET",
            "header": [{ "key": "X-School-Id", "value": "{{schoolId}}" }],
            "url": { "raw": "{{baseUrl}}/api/v1/admin/registry/duplicates", "host": ["{{baseUrl}}"], "path": ["api","v1","admin","registry","duplicates"] }
          }
        },
        {
          "name": "Merge Duplicates",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "X-School-Id", "value": "{{schoolId}}" }],
            "body": { "mode": "raw", "raw": "{\n  \"keep_token\": \"<winner_token>\",\n  \"merge_token\": \"<loser_token>\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/v1/admin/registry/merge", "host": ["{{baseUrl}}"], "path": ["api","v1","admin","registry","merge"] }
          }
        },
        {
          "name": "Keep Both (dismiss duplicate flag)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "X-School-Id", "value": "{{schoolId}}" }],
            "body": { "mode": "raw", "raw": "{\n  \"token_a\": \"<token_a>\",\n  \"token_b\": \"<token_b>\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/v1/admin/registry/keep-both", "host": ["{{baseUrl}}"], "path": ["api","v1","admin","registry","keep-both"] }
          }
        }
      ]
    },

    {
      "name": "User Management (school-scoped)",
      "item": [
        { "name": "List Users", "request": { "method": "GET", "header": [{ "key": "X-School-Id", "value": "{{schoolId}}" }], "url": { "raw": "{{baseUrl}}/api/v1/users", "host": ["{{baseUrl}}"], "path": ["api","v1","users"] } } },
        {
