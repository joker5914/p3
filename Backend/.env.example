# ============================================================
# Dismissal Environment Configuration — EXAMPLE FILE
# Copy to .env and fill in real values.
# NEVER commit .env to source control.
# ============================================================

# 🌐 Environment: 'production' or 'development'
ENV=development

# 🔐 Cryptographic secrets
# Generate SECRET_KEY:  python -c "import secrets; print(secrets.token_hex(32))"
# Generate ENCRYPTION:  python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SECRET_KEY=REPLACE_ME_32_BYTE_HEX
DISMISSAL_ENCRYPTION_KEY=REPLACE_ME_FERNET_KEY

# 🏫 Dev school identifier (used when ENV=development)
DEV_SCHOOL_ID=dev_school

# 🕐 Timezone for the scanner device (IANA tz name)
DEVICE_TIMEZONE=America/New_York

# 🚧 DEVELOPMENT URLs
VITE_DEV_BACKEND_URL=http://localhost:8000
VITE_DEV_FRONTEND_URL=http://localhost:5173

# 🚀 PRODUCTION URLs (Cloud Run + Firebase Hosting)
VITE_PROD_BACKEND_URL=https://YOUR_CLOUD_RUN_URL.run.app
VITE_PROD_FRONTEND_URL=https://YOUR_PROJECT.web.app

# 📂 Path to Firebase service-account JSON (development only)
# In production, use Application Default Credentials instead.
FIREBASE_CREDENTIALS_PATH=firebase_credentials.json

# =============================================================
# 📷 Scanner settings (Raspberry Pi / dismissal.py)
# =============================================================

# Camera source — set URL for RTSP/HTTP stream, leave blank to use INDEX
SCANNER_CAMERA_URL=
SCANNER_CAMERA_INDEX=0

# Resolution requested from the camera driver
SCANNER_RESOLUTION=1280x720

# Max frames to run through the detection pipeline per second
# Lower = less CPU/TPU load; higher = faster detection response
SCANNER_FPS_CAP=10

# Seconds to suppress repeated submissions of the same plate
SCANNER_COOLDOWN_SECS=30

# Minimum OCR confidence (0.0 – 1.0) to accept a reading
SCANNER_MIN_CONFIDENCE=0.70

# Valid plate string length range (adjust for your region)
SCANNER_MIN_PLATE_LEN=4
SCANNER_MAX_PLATE_LEN=8

# Write annotated debug frames to ./debug_frames/ (set true while tuning)
SCANNER_DEBUG=false

# Optional: path to an EdgeTPU-compiled .tflite plate detection model
# Leave blank to use the OpenCV contour detector (no TPU required)
SCANNER_MODEL_PATH=

# Label attached to every scan event (identifies which scanner sent it)
SCANNER_LOCATION=entry_scanner_1

# HTTP retry settings for the scanner POST client
SCANNER_TIMEOUT_SECS=10
SCANNER_MAX_RETRIES=5
