# ============================================================
# Dismissal Environment Configuration — EXAMPLE FILE
# Copy to .env and fill in real values.
# NEVER commit .env to source control.
# ============================================================

# 🌐 Environment: 'production' or 'development'
ENV=development

# 🔐 Cryptographic secrets (server-side only, not needed on scanner Pi)
# Generate SECRET_KEY:  python -c "import secrets; print(secrets.token_hex(32))"
# Generate ENCRYPTION:  python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SECRET_KEY=REPLACE_ME_32_BYTE_HEX
DISMISSAL_ENCRYPTION_KEY=REPLACE_ME_FERNET_KEY

# 🏫 Dev school identifier (used when ENV=development)
DEV_SCHOOL_ID=dev_school

# 🕐 Timezone for the scanner device (IANA tz name)
DEVICE_TIMEZONE=America/New_York

# 🚧 DEVELOPMENT URLs (server-side only; scanner reads scanner_config.py)
VITE_DEV_BACKEND_URL=http://localhost:8000
VITE_DEV_FRONTEND_URL=http://localhost:5173

# 🚀 PRODUCTION URLs (server-side only)
VITE_PROD_BACKEND_URL=https://YOUR_CLOUD_RUN_URL.run.app
VITE_PROD_FRONTEND_URL=https://YOUR_PROJECT.web.app

# 📂 Path to Firebase service-account JSON (server-side; dev only).
# In production, use Application Default Credentials instead.
FIREBASE_CREDENTIALS_PATH=firebase_credentials.json

# ✉️  Transactional email (Resend — https://resend.com)
# Used to send admin/staff invite emails from /api/v1/users/invite.
# Leave RESEND_API_KEY unset to disable email delivery; the invite UI falls
# back to showing the copy-to-clipboard link as before.
RESEND_API_KEY=
# Sender address.  MUST be on a domain you've verified in Resend for
# production use.  For development without a verified domain, leave as
# onboarding@resend.dev — Resend's sandbox address; it only delivers to
# the email on your Resend account.
RESEND_FROM_EMAIL=onboarding@resend.dev
# Optional Reply-To header.  If set, recipient's Reply goes here instead
# of the sender.  Leave blank to omit.
RESEND_REPLY_TO=
# Product name used in email subject / body.
INVITE_PRODUCT_NAME=Dismissal

# =============================================================
# 🛰️ Scanner (Raspberry Pi) — OPTIONAL overrides
# =============================================================
# Under the simplified deployment flow, the scanner reads its backend URL and
# Firebase Web API key from Backend/scanner_config.py (committed, public).
# The only runtime secret is the service-account JSON, installed via
# prepare-sdcard.sh --service-account-json FILE.
#
# Everything below is OPTIONAL — only set when overriding a default:

# Path to the Firebase service-account JSON (default: /opt/dismissal/Backend/firebase-scanner-sa.json)
# FIREBASE_SERVICE_ACCOUNT_JSON=/opt/dismissal/Backend/firebase-scanner-sa.json

# Custom UID used when minting tokens (default: device hostname)
# SCANNER_DEVICE_UID=

# Override Firebase Web API key (default: scanner_config.FIREBASE_WEB_API_KEY)
# FIREBASE_WEB_API_KEY=

# =============================================================
# 📷 Scanner settings (Raspberry Pi — dismissal.py)
# =============================================================

# Camera source:
#   Leave SCANNER_CAMERA_URL blank to use the Arducam CSI camera via Picamera2
#   (recommended for Pi 5 + Arducam 16MP IMX519).
#   Set SCANNER_CAMERA_URL to an RTSP/HTTP URL to use a network camera instead.
SCANNER_CAMERA_URL=
SCANNER_CAMERA_INDEX=0

# Resolution passed to Picamera2 (or OpenCV for RTSP).
# Arducam IMX519 supports up to 4656x3496; 1920x1080 or 1280x720 for scanning.
# Capture resolution.  1920x1080 gives roughly 2.25× the pixels per
# plate vs 720p at negligible per-frame cost — YOLO still resizes to
# 640 internally and motion gate downscales to 640.  Drop to 1280x720
# only if the main loop FPS can't keep up on your hardware.
SCANNER_RESOLUTION=1920x1080

# Capture framerate (Picamera2 sensor framerate)
SCANNER_CAMERA_FPS=30

# Max frames to run through the detection pipeline per second.
# Lower = less CPU/TPU load. Start at 10 and tune up.
SCANNER_FPS_CAP=10

# Seconds to suppress repeated submissions of the same plate
# Suppress the same plate (or any plate within edit distance 1 —
# catches OCR character flips) for this many seconds.  A real car in
# the pickup queue isn't going to rescan sooner than that; this is
# also long enough to absorb 'car drives past, car drives past again
# a minute later' during testing.
SCANNER_COOLDOWN_SECS=180

# Minimum OCR confidence (0.0–1.0) to accept a reading
SCANNER_MIN_CONFIDENCE=0.75

# Drop every unrecognised-scan post for this many seconds after a
# successful recognised scan.  A car parked in front of the camera
# keeps generating detections while AF settles; OCR on the trailing
# frames often hallucinates characters that are edit-distance >2
# from the plate we just recognised, so pure text-match fuzzy dedup
# can't catch them.  This time gate catches them cleanly.
SCANNER_UNREC_SUPPRESS_WINDOW_SECS=60

# N-of-M frame-agreement filter on OCR output.  A plate must OCR the
# same way on at least SCANNER_CONFIRM_MIN_HITS of the last
# SCANNER_CONFIRM_WINDOW observations (each within
# SCANNER_CONFIRM_TTL_SECS) before it's forwarded to the backend.
# This cuts character-flip noise (6↔G, 0↔D, 7↔1) where the correct
# plate still dominates across frames.  Set MIN_HITS=1 to disable.
SCANNER_CONFIRM_MIN_HITS=2
SCANNER_CONFIRM_WINDOW=5
SCANNER_CONFIRM_TTL_SECS=5.0

# Minimum OCR confidence required to forward an *unrecognized* scan to
# the backend.  Without this gate every vehicle that passes (even with
# Tesseract returning nothing readable) shows up as a 0% Unknown Vehicle
# card on the Dashboard.  Set to 0.0 to post every near-miss for visual
# debugging.
SCANNER_MIN_UNRECOGNIZED_CONFIDENCE=0.60

# Valid plate string length range (adjust for your region)
SCANNER_MIN_PLATE_LEN=4
SCANNER_MAX_PLATE_LEN=8

# Write annotated debug frames to ./debug_frames/ (set true while tuning)
SCANNER_DEBUG=false

# LAN-only live debug view: http://<pi-ip>:<port>/ shows the camera
# feed with detection overlays so an operator can confirm the scanner
# is actually seeing vehicles.  Set to 0 to disable.  No auth — keep
# the port on the LAN.
SCANNER_DEBUG_PORT=8081

# Optional fixed focus for permanent installations.  Value is in
# diopters (1 / distance_in_metres):
#   0.0  = infinity             0.33 = 3 m
#   0.10 = 10 m                 0.50 = 2 m
#   0.20 = 5 m                  1.0  = 1 m
# Leave blank to use continuous autofocus with motion-guided AF windows
# (the default — the main loop points AF at wherever motion is).
SCANNER_LENS_POSITION=

# Vehicle detector model paths.  install.sh downloads both of these
# (SSD-MobileNet-v2 COCO quantised, from google-coral/test_data).
#   SCANNER_MODEL_PATH      : Edge TPU variant, used only when a Coral
#                             is plugged in and libedgetpu is loadable.
#   SCANNER_MODEL_PATH_CPU  : CPU variant.  Runs on the Pi 5 ARM cores
#                             at ~5–10 FPS with no accelerator required.
# If neither file exists, the scanner silently falls back to contour-only
# plate detection (works but has many false positives).
SCANNER_MODEL_PATH=/opt/dismissal/models/ssd_mobilenet_v2_coco_quant_postprocess_edgetpu.tflite
SCANNER_MODEL_PATH_CPU=/opt/dismissal/models/ssd_mobilenet_v2_coco_quant_postprocess.tflite

# Direct plate detector — YOLOv8 ONNX model trained on license plates.
# Works for close-ups and angles where no full vehicle is in frame.
# Install with:  sudo bash /opt/dismissal/deploy/install_plate_model.sh
SCANNER_PLATE_MODEL_PATH=/opt/dismissal/models/plate_yolo.onnx

# Opt-in to the Edge TPU delegate.  Leave off until you've confirmed the
# delegate loads cleanly on your Pi — some tflite-runtime / ai-edge-litert
# + libedgetpu combos SEGV in the delegate instead of throwing a
# catchable exception, which systemd then respawns in a loop.
SCANNER_USE_EDGETPU=0

# Raspberry Pi AI HAT+ (Hailo-8L / Hailo-8) offload.  Install with:
#   sudo bash /opt/dismissal/deploy/install_hailo_model.sh
# then copy a compiled plate_yolo.hef into /opt/dismissal/models/ and
# flip this on.  Falls back to the ONNX CPU YOLO automatically if the
# .hef is missing or hailo_platform can't be imported.
SCANNER_USE_HAILO=0
SCANNER_PLATE_MODEL_HEF_PATH=/opt/dismissal/models/plate_yolo.hef

# Label attached to every scan event (identifies which scanner POSTed it)
SCANNER_LOCATION=entry_scanner_1

# HTTP client settings
SCANNER_TIMEOUT_SECS=10

# Path to SQLite durable outbox (scans queued here survive network outages)
# systemd StateDirectory=dismissal creates /var/lib/dismissal automatically.
SCANNER_OUTBOX_PATH=/var/lib/dismissal/outbox.db

# =============================================================
# 🐕 Watchdog settings (dismissal_watchdog.py)
# =============================================================
WATCHDOG_CHECK_INTERVAL=30
WATCHDOG_WIFI_IFACE=wlan0

# =============================================================
# 🩺 Health endpoint settings (dismissal_health.py)
# =============================================================
HEALTH_PORT=9000
