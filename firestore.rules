rules_version = '2';

// =============================================================================
// Dismissal Firestore Security Rules
// =============================================================================
// Deploy with:  firebase deploy --only firestore:rules
//
// Philosophy:
//   - All reads/writes require a valid Firebase Auth token.
//   - Every document is scoped to a school_id — users can only access
//     data belonging to their own school.
//   - school_id is stored as a custom claim in the Firebase JWT so rules
//     can enforce it without an extra Firestore read.
//   - The backend (Cloud Run service account) bypasses these rules via
//     the Admin SDK — client-side rules only apply to direct SDK access.
// =============================================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // -------------------------------------------------------------------------
    // Helper functions
    // -------------------------------------------------------------------------

    // Is the caller authenticated at all?
    function isAuthed() {
      return request.auth != null;
    }

    // Extract school_id from the Firebase custom claim (set by invite_user).
    // Falls back to uid if no claim is present (legacy / first admin).
    function callerSchoolId() {
      return request.auth.token.get('school_id', request.auth.uid);
    }

    // Does the caller's school_id match the document's school_id?
    function sameSchool(docData) {
      return docData.school_id == callerSchoolId();
    }

    // Does the caller have the school_admin role (via custom claim)?
    function isSchoolAdmin() {
      return request.auth.token.get('role', '') == 'school_admin';
    }

    // Is the incoming data scoped to the caller's school?
    function incomingSameSchool() {
      return request.resource.data.school_id == callerSchoolId();
    }

    // -------------------------------------------------------------------------
    // plates — plate registry
    // -------------------------------------------------------------------------
    // Document ID  : HMAC-SHA256 plate token (set by backend)
    // Read         : any authenticated user of the same school (staff need to
    //                verify plates on the dashboard)
    // Write        : school_admin only (import, add, delete)
    // -------------------------------------------------------------------------
    match /plates/{plateToken} {
      allow read: if isAuthed() && sameSchool(resource.data);

      allow create: if isAuthed()
                    && isSchoolAdmin()
                    && incomingSameSchool();

      allow update: if isAuthed()
                    && isSchoolAdmin()
                    && sameSchool(resource.data)
                    && incomingSameSchool();

      allow delete: if isAuthed()
                    && isSchoolAdmin()
                    && sameSchool(resource.data);
    }

    // -------------------------------------------------------------------------
    // plate_scans — scan event log
    // -------------------------------------------------------------------------
    // Document ID  : auto-generated by Firestore (via backend .add())
    // Read         : any authenticated user of the same school
    // Write        : only the backend service account writes here;
    //                client-side create/update/delete is blocked entirely
    //                (the backend Admin SDK bypasses these rules)
    // Delete (clear): school_admin only
    // -------------------------------------------------------------------------
    match /plate_scans/{scanId} {
      allow read: if isAuthed() && sameSchool(resource.data);

      // Client-side writes are disabled — only the backend Admin SDK writes here.
      allow create, update: if false;

      allow delete: if isAuthed()
                    && isSchoolAdmin()
                    && sameSchool(resource.data);
    }

    // -------------------------------------------------------------------------
    // school_admins — user management
    // -------------------------------------------------------------------------
    // Document ID  : Firebase Auth UID
    // Read own     : any user can read their own document (for /api/v1/me)
    // Read others  : school_admin can list all users in their school
    // Write        : school_admin only (invite, role/status changes)
    // Own delete   : blocked (can't delete yourself)
    // -------------------------------------------------------------------------
    match /school_admins/{uid} {
      // Users can always read their own record
      allow read: if isAuthed()
                  && (request.auth.uid == uid
                      || (isSchoolAdmin() && sameSchool(resource.data)));

      // Only admins can create user records (via invite flow)
      allow create: if isAuthed()
                    && isSchoolAdmin()
                    && incomingSameSchool();

      // Admins can update others; any user can update their own status
      // (pending → active transition on first login, handled by /api/v1/me)
      allow update: if isAuthed()
                    && (
                      // Admin updating someone else in the same school
                      (isSchoolAdmin()
                        && sameSchool(resource.data)
                        && incomingSameSchool()
                        && request.auth.uid != uid)
                      ||
                      // User activating their own pending account
                      (request.auth.uid == uid
                        && request.resource.data.diff(resource.data).affectedKeys()
                           .hasOnly(['status']))
                    );

      // Admins can delete others (not themselves — enforced in backend too)
      allow delete: if isAuthed()
                    && isSchoolAdmin()
                    && sameSchool(resource.data)
                    && request.auth.uid != uid;
    }

    // -------------------------------------------------------------------------
    // scan_history — archived scans (moved from plate_scans by backend)
    // -------------------------------------------------------------------------
    // Document ID  : auto-generated by Firestore
    // Read         : any authenticated user of the same school (history page)
    // Write        : only the backend service account writes/deletes here;
    //                client-side create/update/delete is blocked entirely
    //                (the backend Admin SDK bypasses these rules)
    // -------------------------------------------------------------------------
    match /scan_history/{scanId} {
      allow read: if isAuthed() && sameSchool(resource.data);

      allow create, update, delete: if false;
    }

    // -------------------------------------------------------------------------
    // guardians — guardian/parent profiles
    // -------------------------------------------------------------------------
    // Document ID  : Firebase Auth UID
    // Read own     : guardian can read their own profile
    // Write        : only the backend Admin SDK writes here
    // -------------------------------------------------------------------------
    match /guardians/{uid} {
      allow read: if isAuthed() && request.auth.uid == uid;

      allow create, update, delete: if false;
    }

    // -------------------------------------------------------------------------
    // students — student records linked to guardians
    // -------------------------------------------------------------------------
    // Document ID  : auto-generated
    // Read         : guardian can read their own children;
    //                school_admin can read students in their school
    // Write        : only the backend Admin SDK writes here
    // -------------------------------------------------------------------------
    match /students/{studentId} {
      allow read: if isAuthed()
                  && (resource.data.guardian_uid == request.auth.uid
                      || (isSchoolAdmin() && sameSchool(resource.data)));

      allow create, update, delete: if false;
    }

    // -------------------------------------------------------------------------
    // vehicles — guardian vehicle records
    // -------------------------------------------------------------------------
    // Document ID  : auto-generated
    // Read         : guardian can read their own vehicles
    // Write        : only the backend Admin SDK writes here
    // -------------------------------------------------------------------------
    match /vehicles/{vehicleId} {
      allow read: if isAuthed()
                  && resource.data.guardian_uid == request.auth.uid;

      allow create, update, delete: if false;
    }

    // -------------------------------------------------------------------------
    // schools — platform school records (super_admin managed)
    // -------------------------------------------------------------------------
    match /schools/{schoolId} {
      allow read: if isAuthed();

      allow create, update, delete: if false;
    }

    // -------------------------------------------------------------------------
    // school_permissions — per-school role permission settings
    // -------------------------------------------------------------------------
    // Document ID matches the school_id.  The backend auto-provisions this
    // document (with a school_id field) whenever a school is created, so a
    // matching document always exists for active schools.
    // Writes are backend-only (Admin SDK bypasses rules).
    // -------------------------------------------------------------------------
    match /school_permissions/{schoolId} {
      allow read: if isAuthed() && resource.data.school_id == callerSchoolId();

      allow create, update, delete: if false;
    }

    // -------------------------------------------------------------------------
    // sis_sync_jobs / sis_duplicates — backend-only SIS integration records
    // -------------------------------------------------------------------------
    // Written by core/sync.py via the Admin SDK (bypasses these rules).
    // Clients never read directly — the UI hits GET /api/v1/admin/... which
    // enforces per-district role scoping.  Denying client access here keeps
    // the posture aligned with the audit log: "nothing reads SIS data except
    // through the backend".
    // -------------------------------------------------------------------------
    match /sis_sync_jobs/{jobId} {
      allow read, write: if false;
    }
    match /sis_duplicates/{dupId} {
      allow read, write: if false;
    }

    // -------------------------------------------------------------------------
    // audit_log — backend-only activity trail (issue #86)
    // -------------------------------------------------------------------------
    // Document ID  : auto-generated by Firestore
    // Read/Write   : blocked for ALL client SDKs.  The audit log is
    //                authoritative and its integrity matters — every
    //                access goes through the backend (Admin SDK bypasses
    //                these rules), so admins can't view their own entries
    //                to, say, redact a role-change event.
    // -------------------------------------------------------------------------
    match /audit_log/{eventId} {
      allow read, write: if false;
    }

    // -------------------------------------------------------------------------
    // Deny everything else
    // -------------------------------------------------------------------------
    // This catches any stale collections (e.g. the old 'imported_data')
    // and prevents accidental access to undeclared paths.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
