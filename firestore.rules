rules_version = '2';

// =============================================================================
// P3 Firestore Security Rules
// =============================================================================
// Deploy with:  firebase deploy --only firestore:rules
//
// Philosophy:
//   - All reads/writes require a valid Firebase Auth token.
//   - Every document is scoped to a school_id — users can only access
//     data belonging to their own school.
//   - school_id is stored as a custom claim in the Firebase JWT so rules
//     can enforce it without an extra Firestore read.
//   - The backend (Cloud Run service account) bypasses these rules via
//     the Admin SDK — client-side rules only apply to direct SDK access.
// =============================================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // -------------------------------------------------------------------------
    // Helper functions
    // -------------------------------------------------------------------------

    // Is the caller authenticated at all?
    function isAuthed() {
      return request.auth != null;
    }

    // Extract school_id from the Firebase custom claim (set by invite_user).
    // Falls back to uid if no claim is present (legacy / first admin).
    function callerSchoolId() {
      return request.auth.token.get('school_id', request.auth.uid);
    }

    // Does the caller's school_id match the document's school_id?
    function sameSchool(docData) {
      return docData.school_id == callerSchoolId();
    }

    // Does the caller have the school_admin role (via custom claim)?
    function isSchoolAdmin() {
      return request.auth.token.get('role', '') == 'school_admin';
    }

    // Is the incoming data scoped to the caller's school?
    function incomingSameSchool() {
      return request.resource.data.school_id == callerSchoolId();
    }

    // -------------------------------------------------------------------------
    // plates — plate registry
    // -------------------------------------------------------------------------
    // Document ID  : HMAC-SHA256 plate token (set by backend)
    // Read         : any authenticated user of the same school (staff need to
    //                verify plates on the dashboard)
    // Write        : school_admin only (import, add, delete)
    // -------------------------------------------------------------------------
    match /plates/{plateToken} {
      allow read: if isAuthed() && sameSchool(resource.data);

      allow create: if isAuthed()
                    && isSchoolAdmin()
                    && incomingSameSchool();

      allow update: if isAuthed()
                    && isSchoolAdmin()
                    && sameSchool(resource.data)
                    && incomingSameSchool();

      allow delete: if isAuthed()
                    && isSchoolAdmin()
                    && sameSchool(resource.data);
    }

    // -------------------------------------------------------------------------
    // plate_scans — scan event log
    // -------------------------------------------------------------------------
    // Document ID  : auto-generated by Firestore (via backend .add())
    // Read         : any authenticated user of the same school
    // Write        : only the backend service account writes here;
    //                client-side create/update/delete is blocked entirely
    //                (the backend Admin SDK bypasses these rules)
    // Delete (clear): school_admin only
    // -------------------------------------------------------------------------
    match /plate_scans/{scanId} {
      allow read: if isAuthed() && sameSchool(resource.data);

      // Client-side writes are disabled — only the backend Admin SDK writes here.
      allow create, update: if false;

      allow delete: if isAuthed()
                    && isSchoolAdmin()
                    && sameSchool(resource.data);
    }

    // -------------------------------------------------------------------------
    // school_admins — user management
    // -------------------------------------------------------------------------
    // Document ID  : Firebase Auth UID
    // Read own     : any user can read their own document (for /api/v1/me)
    // Read others  : school_admin can list all users in their school
    // Write        : school_admin only (invite, role/status changes)
    // Own delete   : blocked (can't delete yourself)
    // -------------------------------------------------------------------------
    match /school_admins/{uid} {
      // Users can always read their own record
      allow read: if isAuthed()
                  && (request.auth.uid == uid
                      || (isSchoolAdmin() && sameSchool(resource.data)));

      // Only admins can create user records (via invite flow)
      allow create: if isAuthed()
                    && isSchoolAdmin()
                    && incomingSameSchool();

      // Admins can update others; any user can update their own status
      // (pending → active transition on first login, handled by /api/v1/me)
      allow update: if isAuthed()
                    && (
                      // Admin updating someone else in the same school
                      (isSchoolAdmin()
                        && sameSchool(resource.data)
                        && incomingSameSchool()
                        && request.auth.uid != uid)
                      ||
                      // User activating their own pending account
                      (request.auth.uid == uid
                        && request.resource.data.diff(resource.data).affectedKeys()
                           .hasOnly(['status']))
                    );

      // Admins can delete others (not themselves — enforced in backend too)
      allow delete: if isAuthed()
                    && isSchoolAdmin()
                    && sameSchool(resource.data)
                    && request.auth.uid != uid;
    }

    // -------------------------------------------------------------------------
    // Deny everything else
    // -------------------------------------------------------------------------
    // This catches any stale collections (e.g. the old 'imported_data')
    // and prevents accidental access to undeclared paths.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
