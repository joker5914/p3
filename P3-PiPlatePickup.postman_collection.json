    {
      "name": "Authentication",
      "item": [
        {
          "name": "Generate Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const resp = pm.response.json();",
                  "    pm.collectionVariables.set(\"token\", resp.idToken);",
                  "",
                  "    pm.test(\"Token generated and saved\", function () {",
                  "        pm.expect(resp.idToken).to.be.a(\"string\");",
                  "        pm.expect(pm.collectionVariables.get(\"token\")).to.not.equal(\"<firebase_id_token>\");",
                  "    });",
                  "",
                  "    pm.test(\"Token expires in ~1 hour\", function () {",
                  "        pm.expect(resp.expiresIn).to.equal(\"3600\");",
                  "    });",
                  "} else {",
                  "    pm.test(\"Token generation failed: \" + pm.response.text(), function () {",
                  "        pm.expect.fail(\"Expected 200 but got \" + pm.response.code);",
                  "    });",
                  "}"
                ]
              }
            },
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// Skip the collection-level auto-token script for this request"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{testEmail}}\",\n  \"password\": \"{{testPassword}}\",\n  \"returnSecureToken\": true\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "https://identitytoolkit.googleapis.com/v1/accounts:signInWithPassword?key={{firebaseApiKey}}",
              "protocol": "https",
              "host": ["identitytoolkit", "googleapis", "com"],
              "path": ["v1", "accounts:signInWithPassword"],
              "query": [
                {
                  "key": "key",
                  "value": "{{firebaseApiKey}}"
                }
              ]
            },
            "description": "Generates a Firebase ID token by signing in with email/password via the Firebase Auth REST API. The test script automatically saves the token to the `token` collection variable so all subsequent requests are authenticated.\n\nThis request uses the `testEmail`, `testPassword`, and `firebaseApiKey` collection variables. Update those variables to use different credentials.\n\nTokens expire after 1 hour. Run this request again to refresh."
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"kind\": \"identitytoolkit#VerifyPasswordResponse\",\n  \"localId\": \"<firebase_uid>\",\n  \"email\": \"scanner01@p3.local\",\n  \"displayName\": \"\",\n  \"idToken\": \"<jwt_id_token>\",\n  \"registered\": true,\n  \"refreshToken\": \"<refresh_token>\",\n  \"expiresIn\": \"3600\"\n}"
            }
          ]
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/logout",
