    {
      "key": "baseUrl",
      "value": "https://p3-backend-375142531842.us-central1.run.app",
      "type": "string"
    },
    {
      "key": "token",
      "value": "<firebase_id_token>",
      "type": "string"
    },
    {
      "key": "firebaseApiKey",
      "value": "AIzaSyAptP2cM_xj764rrwC4FRnbmnQJwFsLvFM",
      "type": "string",
      "description": "Firebase Web API key (from Firebase project settings)"
    },
    {
      "key": "testEmail",
      "value": "scanner01@p3.local",
      "type": "string",
      "description": "Email for the test user used to generate tokens"
    },
    {
      "key": "testPassword",
      "value": "Godisgod59145!",
      "type": "string",
      "description": "Password for the test user used to generate tokens"
    },
    {
      "key": "schoolId",
