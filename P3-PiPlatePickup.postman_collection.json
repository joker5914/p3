  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Auto-generate Firebase ID token if not already set",
          "const token = pm.collectionVariables.get(\"token\");",
          "if (!token || token === \"<firebase_id_token>\") {",
          "    const apiKey = pm.collectionVariables.get(\"firebaseApiKey\");",
          "    const email = pm.collectionVariables.get(\"testEmail\");",
          "    const password = pm.collectionVariables.get(\"testPassword\");",
          "",
          "    pm.sendRequest({",
          "        url: \"https://identitytoolkit.googleapis.com/v1/accounts:signInWithPassword?key=\" + apiKey,",
          "        method: \"POST\",",
          "        header: { \"Content-Type\": \"application/json\" },",
          "        body: {",
          "            mode: \"raw\",",
          "            raw: JSON.stringify({",
          "                email: email,",
          "                password: password,",
          "                returnSecureToken: true",
          "            })",
          "        }",
          "    }, function (err, res) {",
          "        if (!err && res.code === 200) {",
          "            pm.collectionVariables.set(\"token\", res.json().idToken);",
          "            console.log(\"Token auto-generated and saved to collection variables.\");",
          "        } else {",
          "            console.error(\"Token auto-generation failed:\", err || res.text());",
          "        }",
          "    });",
          "}"
        ]
      }
    }
  ],
